# ── Video Generation (ByteDance Seedance 2.0) ─────────────────────────────
# Hackathon key provided — works out of the box
SEEDANCE_API_KEY=a3f914cf-838f-4bd3-91c7-135c33518f40

# ── LLM — Pollinations.ai (FREE, no key needed) ───────────────────────────
# Works out of the box. Optionally get a free key at enter.pollinations.ai
LLM_PROVIDER=pollinations
# POLLINATIONS_API_KEY=optional_key_here

# Other free options (uncomment to use instead):
# LLM_PROVIDER=groq
# GROQ_API_KEY=your_groq_key        # free at console.groq.com
# LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=your_key       # free models at openrouter.ai

# ── Speech (ionrouter.io — provided by hackathon) ─────────────────────────
# edge-tts is used by default (completely free, no key needed)
# ionrouter.io is the fallback
IONROUTER_API_KEY=sk-bb3d84f1cea67cd03ef7e1355f51e184837a72cfd321fbbb

# ── Shopify Webhook ───────────────────────────────────────────────────────
# Get from Shopify Partner Dashboard → App → Client Secret
# Leave empty to skip HMAC verification (dev mode)
SHOPIFY_WEBHOOK_SECRET=your_shopify_client_secret
